local function C_5()
local script = G2L["5"];
	-- ============================================
	-- PAGE HANDLER SCRIPT
	-- ============================================
	-- This script handles switching between different pages in your GUI.
	-- When you add more pages, follow the comments marked with "TODO:"
	-- ============================================
	
	local Players = game:GetService("Players")
	local LocalPlayer = Players.LocalPlayer
	local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")
	
	-- Wait for the GUI to load
	local ScreenGui = PlayerGui:WaitForChild("ScreenGui")
	local MainFrame = ScreenGui:WaitForChild("MainFrame")
	local SideBar = MainFrame:WaitForChild("SideBar")
	local ContentArea = MainFrame:WaitForChild("ContentArea")
	
	-- ============================================
	-- PAGE CONFIGURATION
	-- ============================================
	-- Add your pages here! Each entry needs:
	-- - buttonName: The name of the button in the SideBar
	-- - pageName: The name of the page frame in ContentArea
	-- ============================================
	
	local pageConfig = {
	    {buttonName = "MainPG", pageName = "MainPage"},
	    {buttonName = "SettingsPG", pageName = "SettingsPage"},
	    -- TODO: Add more pages here following the same format:
	    -- {buttonName = "YourButtonName", pageName = "YourPageName"},
	    -- Example:
	    -- {buttonName = "CombatPG", pageName = "CombatPage"},
	    -- {buttonName = "DashboardPG", pageName = "DashboardPage"},
	    -- {buttonName = "VisualPG", pageName = "VisualPage"},
	}
	
	-- ============================================
	-- COLOR CONFIGURATION
	-- ============================================
	-- Customize these colors to match your GUI theme
	local ACTIVE_COLOR = Color3.fromRGB(27, 27, 27)  -- Grey color for active page button
	local INACTIVE_COLOR = Color3.fromRGB(0, 0, 0) -- White color for inactive buttons
	
	-- Track the currently active page
	local currentPage = nil
	local activeButton = nil
	
	-- ============================================
	-- FUNCTION: Switch to a specific page
	-- ============================================
	-- Parameters:
	--   buttonName: Name of the sidebar button that was clicked
	--   pageName: Name of the page frame to show
	-- ============================================
	
	local function switchPage(buttonName, pageName)
	    -- Hide all pages first
	    for _, config in pageConfig do
	        local page = ContentArea:FindFirstChild(config.pageName)
	        if page then
	            page.Visible = false
	        end
	    end
	    
	    -- Reset all buttons to inactive color
	    for _, config in pageConfig do
	        local button = SideBar:FindFirstChild(config.buttonName)
	        if button and button:IsA("TextButton") then
	            button.BackgroundColor3 = INACTIVE_COLOR
	        end
	    end
	    
	    -- Show the selected page
	    local selectedPage = ContentArea:FindFirstChild(pageName)
	    if selectedPage then
	        selectedPage.Visible = true
	        currentPage = pageName
	    else
	        warn("Page not found: " .. pageName)
	    end
	    
	    -- Set the clicked button to active color (grey)
	    local selectedButton = SideBar:FindFirstChild(buttonName)
	    if selectedButton and selectedButton:IsA("TextButton") then
	        selectedButton.BackgroundColor3 = ACTIVE_COLOR
	        activeButton = buttonName
	    end
	end
	
	-- ============================================
	-- SETUP: Connect buttons to their pages
	-- ============================================
	-- This section connects each sidebar button to its corresponding page.
	-- When you add a new page to pageConfig above, you don't need to change this!
	-- ============================================
	
	for _, config in pageConfig do
	    local button = SideBar:FindFirstChild(config.buttonName)
	    
	    if button and button:IsA("TextButton") then
	        button.MouseButton1Click:Connect(function()
	            switchPage(config.buttonName, config.pageName)
	        end)
	    else
	        warn("Button not found: " .. config.buttonName)
	    end
	end
	
	-- ============================================
	-- INITIALIZE: Load MainPage on startup
	-- ============================================
	-- This automatically shows MainPage when the GUI loads.
	-- Change "MainPG" and "MainPage" if you want a different default page.
	-- ============================================
	
	local defaultButton = "MainPG"  -- TODO: Change this to your default button name
	local defaultPage = "MainPage"  -- TODO: Change this to your default page name
	
	-- Wait a moment to ensure everything is loaded
	task.wait(0.1)
	switchPage(defaultButton, defaultPage)
	
	print("Page Handler initialized! Default page: " .. defaultPage)
	
end;
